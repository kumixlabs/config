{
  "name": "@kumix/eslint-config-react",
  "version": "0.0.1",
  "description": "ESLint configuration to use for React projects.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "tsc -b --clean && rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "build": "tsc",
    "types:check": "tsc --noEmit"
  },
  "homepage": "https://github.com/kumixlabs/config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/config.git",
    "directory": "packages/eslint-config-react"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/config/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "eslint",
    "eslintconfig",
    "configuration",
    "config",
    "react",
    "typescript",
    "linting",
    "code-style"
  ],
  "dependencies": {
    "@kumix/eslint-config": "workspace:*",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.62.1"
  },
  "devDependencies": {
    "@kumix/tsconfig": "workspace:*",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": ">=9.30.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
