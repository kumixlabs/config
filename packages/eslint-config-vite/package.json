{
  "name": "@kumix/eslint-config-vite",
  "version": "0.1.1",
  "description": "ESLint configuration for Vite projects with React Refresh support.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo coverage dist node_modules",
    "build": "tsc -p tsconfig.build.json",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "homepage": "https://github.com/kumixlabs/config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/config.git",
    "directory": "packages/eslint-config-vite"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/config/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "eslint",
    "eslintconfig",
    "configuration",
    "config",
    "vite",
    "react-refresh",
    "typescript",
    "linting",
    "code-style"
  ],
  "dependencies": {
    "@kumix/eslint-config": "workspace:*",
    "@kumix/eslint-config-react": "workspace:*",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript-eslint": "^8.63.0"
  },
  "devDependencies": {
    "@kumix/tsconfig": "workspace:*",
    "eslint": "^10.7.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9.30.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
